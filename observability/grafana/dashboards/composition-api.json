          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(ogen_server_request_count_total{http_response_status_code=~\"5..\"}[$__rate_interval])) or (0 * absent(ogen_server_request_count_total{http_response_status_code=~\"5..\"}))",
