      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(sum by (http_request_method) (rate(ogen_server_request_count_total{http_route=\"$route\"}[$__rate_interval])) or (0 * absent(ogen_server_request_count_total{http_route=\"$route\"})))",
          "legendFormat": "{{http_request_method}}",
          "refId": "A"
        }
      ],
      "title": "$route — запросов / сек",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "p50/p95; без данных по ручке — линия на нуле.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
      "id": 12,
      "repeat": "route",
      "repeatDirection": "h",
      "maxPerRow": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}},
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(histogram_quantile(0.50, sum by (le) (rate(ogen_server_duration_milliseconds_bucket{http_route=\"$route\"}[$__rate_interval]))) or (0 * absent(ogen_server_duration_milliseconds_bucket{http_route=\"$route\"})))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(histogram_quantile(0.95, sum by (le) (rate(ogen_server_duration_milliseconds_bucket{http_route=\"$route\"}[$__rate_interval]))) or (0 * absent(ogen_server_duration_milliseconds_bucket{http_route=\"$route\"})))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "$route — время ответа (мс)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
